// T1566.002 - Hunt for OAuth Phishing (User granting app access)
OfficeActivity
// Look for the specific event where a user clicks "Accept" on an app
| where Operation == "ConsentToApplication"
// Extract the permissions (Scopes) and App Name from the raw log data
| extend Scopes = parse_json(ExtendedProperties).Scopes
| extend ClientAppName = tostring(parse_json(ExtendedProperties).Application)
// Filter for dangerous permissions like full mailbox or CRM access
| where Scopes has_any ("full_access", "mail.read", "crm.data.read")
// Display the key info: Who, What App, and What Permissions
| project TimeGenerated, UserId, ClientAppName, ClientAppId, Scopes, Operation, ClientIP
